{
  // Theme & Appearance
  // Extensions:
  // sainnhe.everforest
  // PKief.material-icon-theme
  "workbench.colorTheme": "Everforest Dark",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorCustomizations": {
    "[Everforest Dark]": {
      "scrollbar.shadow": "#0000",
      "panel.border": "#0000",
      "sideBar.border": "#0000",
      "editorHoverWidget.border": "#0000",
      "panel.background": "#272e33",
      "sideBar.background": "#272e33"
    }
  },
  /* "editor.tokenColorCustomizations": {
    "[Everforest Dark]": {}
  }, */

  // Workbench
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": false,
  "workbench.layoutControl.enabled": false,
  "workbench.startupEditor": "none",
  "workbench.tree.renderIndentGuides": "none",
  "workbench.editor.enablePreview": false,
  "workbench.tips.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.tree.enableStickyScroll": false,

  // Editor
  "editor.fontFamily": "Consolas",
  "editor.fontSize": 15,
  "editor.lineHeight": 2.0,
  "editor.wordWrapColumn": 100,
  "editor.wordWrap": "wordWrapColumn",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "none",
  "editor.stickyScroll.enabled": false,
  "editor.renderLineHighlight": "gutter",
  "editor.selectionHighlight": false,
  "editor.guides.indentation": false,
  "editor.lightbulb.enabled": "off",
  "editor.occurrencesHighlight": "off",
  "editor.foldingHighlight": false,
  "editor.detectIndentation": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.roundedSelection": false,
  "editor.smoothScrolling": true,
  "editor.hideCursorInOverviewRuler": true,
  "editor.overviewRulerBorder": false,
  "editor.mouseWheelScrollSensitivity": 2.5,

  // Terminal
  // Dependencies:
  // Git Bash (https://git-scm.com/install/)
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.tabs.enabled": false,

  // Explorer & Files
  "explorer.decorations.badges": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "files.dialog.defaultPath": "C:\\Users\\salma\\Documents",
  "material-icon-theme.folders.theme": "classic",
  "material-icon-theme.hidesExplorerArrows": true,
  "files.associations": {
    "*.env": "properties"
  },
  "material-icon-theme.files.associations": {},

  // Window & UI
  "window.menuBarVisibility": "toggle",
  "window.commandCenter": false,
  "breadcrumbs.enabled": false,
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "chat.commandCenter.enabled": false,
  "chat.agent.enabled": false,
  //   "window.zoomLevel": 0,

  // Version Control
  "git.decorations.enabled": false,
  "scm.diffDecorations": "none",

  // Python
  // Extensions:
  // ms-python.python
  // charliermarsh.ruff
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.organizeImports": "always"
    }
  },
  "ruff.interpreter": [
    "C:\\Users\\salma\\AppData\\Roaming\\uv\\tools\\ruff\\Scripts\\python.exe"
  ],

  // HTML & Jinja
  // Extensions:
  // vincaslt.highlight-matching-tag
  // anteprimorac.html-end-tag-labels
  // wholroyd.jinja
  // noxiz.jinja-snippets
  // monosans.djlint
  "[html]": {
    "editor.defaultFormatter": "monosans.djlint",
    "editor.formatOnSave": true
  },
  "djlint.configuration": "C:\\Users\\salma\\AppData\\Roaming\\djlint\\djlint.toml",
  "djlint.useVenv": false,
  "djlint.pythonPath": "C:\\Users\\salma\\AppData\\Roaming\\uv\\tools\\djlint\\Scripts\\python.exe",

  // TOML
  // Extensions:
  // tamasfe.even-better-toml
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // JSON
  // Extensions:
  // esbenp.prettier-vscode
  "[json][jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // Bash
  // Extensions:
  // timonwong.shellcheck
  // shell-format by foxundermoon
  // Remisa.shellman
  // mkhl.shfmt
  // Dependencies:
  // shftmt (https://webinstall.dev/shfmt/)
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.formatOnSave": true
  },

  // JavaScript
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // usernamehw.errorlens
  "errorLens.fontStyleItalic": true,
  "errorLens.messageBackgroundMode": "none",

  // formulahendry.code-runner
  "code-runner.runInTerminal": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.ignoreSelection": true,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.executorMap": {
    // "<language>": "<commands>"
    "python": "clear; uv run $fullFileName"
  }
}
