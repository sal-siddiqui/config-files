# ~/.config/nano/nanorc

# Editor
set linenumbers
set minibar
set nohelp

# Indentation
set tabsize 2
set autoindent

# Wrapping
set softwrap
set atblanks

# Syntac highlighting
include "/usr/share/nano/*.nanorc"

# Colors
set numbercolor     gray,normal  # numbers
set minicolor       blue,normal  # minibar
set spotlightcolor  white,blue   # searching
set selectedcolor   white,black  # highlighting
set promptcolor     blue,black   # prompt
set statuscolor     white,blue   # messages
set errorcolor      white,red    # error messages
set keycolor        blue,normal  # keyboard shortcuts
set functioncolor   blue,normal  # keyboard shortcuts actions

# Keybindings
bind ^F right all
bind M-F nextword all
bind ^B left all
bind M-B prevword all
