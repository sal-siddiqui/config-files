{
  // --- List of dependencies ---
  // Themes: 3ash.nord-flat, PKief.material-icon-theme
  // Tools: esbenp.prettier-vscode, formulahendry.code-runner, usernamehw.errorlens, ms-vscode-remote.remote-wsl, ms-vscode-remote.remote-containers
  // Python: ms-python.python, charliermarsh.ruff
  // HTML: vincaslt.highlight-matching-tag, anteprimorac.html-end-tag-labels
  // Jinja: wholroyd.jinja, noxiz.jinja-snippets, monosans.djlint
  // JavaScript: dbaeumer.vscode-eslint
  // Bash: timonwong.shellcheck, mads-hartmann.bash-ide-vscode
  // Docker: jeff-hykin.better-dockerfile-syntax

  // Editor
  "editor.fontFamily": "Hack",
  "editor.fontSize": 15,
  "editor.guides.indentation": false,
  "editor.insertSpaces": false,
  "editor.lineHeight": 2,
  "editor.minimap.enabled": false,
  "editor.occurrencesHighlight": "off",
  "editor.selectionHighlight": false,
  "editor.stickyScroll.enabled": false,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 100,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always"
  },

  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  "workbench.colorTheme": "Nord Flat",
  "workbench.activityBar.location": "hidden",
  "workbench.editor.enablePreview": false,
  "workbench.layoutControl.enabled": false,
  "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": false,
  "workbench.startupEditor": "none",
  "workbench.colorCustomizations": {
    "[Nord Flat]": {
      "list.hoverBackground": "#2e344099",
      "list.hoverForeground": "#88c0d0",
      "quickInputList.focusForeground": "#88c0d0",
      "editorWhitespace.foreground": "#81a1c199"
    }
  },

  "window.menuBarVisibility": "toggle",
  "window.commandCenter": false,

  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,

  "breadcrumbs.enabled": false,

  // Explorer
  "workbench.tree.renderIndentGuides": "none",
  "workbench.tree.enableStickyScroll": false,
  "material-icon-theme.folders.theme": "classic",
  "material-icon-theme.hidesExplorerArrows": true,

  // Terminal
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.initialHint": false,

  // Version Control
  "git.decorations.enabled": false,
  "scm.diffDecorations": "none",

  // Error Lens
  "errorLens.messageBackgroundMode": "none",

  // WSL
  "security.workspace.trust.untrustedFiles": "prompt",

  // Bash (WSL)
  "bashIde.shellcheckPath": "/usr/bin/shellcheck",
  "bashIde.shfmt.path": "/usr/bin/shfmt",

  //  JSON, JSONC, & YAML
  "[json][jsonc][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
