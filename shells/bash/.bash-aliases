# Common
alias c='clear'

alias l='ls --color --classify'
alias ll='l -l'
alias la='l --almost-all'

# Git
alias gs='git.exe status --short'
alias gb='git.exe branch -vv --all'
alias gd='git.exe diff --output-indicator-new=" " --output-indicator-old=" "'
alias gl='git.exe log --all --graph --pretty=format:\
"%C(blue)%h %C(brightblack)%an %ar %C(blue)%D%C(reset)%n%s%n"'

# Docker & Kubernetes
alias mk='minikube.exe'
alias kc='kubectl.exe'
alias kpods='kubectl.exe get pods'
alias kapps='kubectl.exe get services,deployments,statefulsets'
alias kw='watch kubectl.exe get'

# Navigation
function popd() { builtin popd >/dev/null; }
function pushd() {
	if (($# == 0)); then
		builtin pushd "$HOME" >/dev/null
	elif [[ $1 == "-" ]]; then
		builtin popd >/dev/null
	else
		builtin pushd "$1" >/dev/null
	fi
}

alias cd='pushd'
alias back='popd'
