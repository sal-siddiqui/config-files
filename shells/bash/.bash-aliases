# Common
alias c='clear'

alias l='ls --color --classify'
alias ll='l -l --human-readable'
alias la='l --almost-all'

alias pl='ps -o pid,ppid,etime,%cpu,%mem,user=USER,stat=STATE,args'

# Git
alias gs='git.exe status --short'
alias gl='git.exe log --all --graph --pretty=format:\
"%C(blue)%h %C(brightblack)%an %ar %C(blue)%D%C(reset)%n%s%n"'
alias gb='git.exe branch -vv'

# Docker & Kubernetes
alias d='docker.exe'
alias m='minikube.exe'
alias k='kubectl.exe'

# Navigation
function popd() { builtin popd > /dev/null; }
alias back='popd'

function pushd() {
	if (($# == 0)); then
		builtin pushd "$HOME" > /dev/null
	elif [[ $1 == "-" ]]; then
		builtin popd > /dev/null
	else
		builtin pushd "$1" > /dev/null
	fi
}
alias cd='pushd'
