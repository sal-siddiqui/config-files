function ff() {
	(($# < 1)) && return 1

	local find_args=()
	local pattern
	for pattern in "$@"; do
		find_args+=(-iname "*$pattern*" -o)
	done
	unset 'find_args[${#find_args[@]}-1]' # remove last '-o'

	find . -type f '(' "${find_args[@]}" ')' 2> /dev/null
}

function fcd() {
	local dir=$(find . -mindepth 1 -type d -name '.*' -prune -o -type d -print 2> /dev/null | fzf.exe --prompt='cd ')
	[[ -n $dir ]] && cd "$dir"
}

function fnano() {
	local files
	readarray -t files < <(
		find . -type f 2> /dev/null |
			fzf.exe --multi --prompt='nano '
	)
	(("${#files[@]}" != 0)) && nano "${files[@]}"
}

function hl() {
	local IFS='|'
	local pattern="$*"
	grep --color=always -E "$|${pattern}"
}

# dl <resource>
# List docker resources in an opioniated format
function dl() {
	local resource format
	case "$1" in
		i)
			resource='image'
			format='table {{.Repository}}:{{.Tag}}\t{{.Containers}}\t{{.Size}}'
			;;
		c)
			resource='container'
			format='table {{.Names}}\t{{.Image}}\t{{upper .State}}\t{{.Networks}}\t{{.Ports}}'
			;;
		*)
			echo 'Usage: dl <resource>'
			echo '  i --> images'
			echo '  c --> containers'
			return 1
			;;
	esac

	docker.exe "$resource" list --all --format "$format"
}

# kl [-n namespace] [-w] <resource...>
# Wrapper for kubectl.exe get
function kl() {
	local namespace watch_mode
	while :; do
		case "$1" in
			'-n')
				namespace=$2
				shift
				;;
			'-w' | --watch)
				watch_mode="watch_mode"
				;;
			*)
				break
				;;
		esac
		shift
	done

	if (($# == 0)); then
		echo 'Usage: kl [-n namespace] [-w|--watch] <resource...>'
		echo '  p  --> pods'
		echo '  d  --> deployments'
		echo '  s  --> services'
		return 1
	fi

	local -A resource_map=(
		[p]=pods [pods]=pods
		[d]=deployments [deployments]=deployments
		[s]=services [services]=services
	)

	local resources=()
	while (($#)); do
		resources+=("${resource_map[$1]}")
		shift
	done

	local IFS=','
	local resources_str="${resources[*]}"

	if [[ -n $watch_mode ]]; then
		watch "kubectl.exe get --namespace=$namespace $resources_str"
	else
		kubectl.exe get --namespace="$namespace" "$resources_str"
	fi
}
